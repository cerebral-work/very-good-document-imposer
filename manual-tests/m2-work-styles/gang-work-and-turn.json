{
  "schema": "vgdi/jobspec@1",
  "sources": [
    { "id": "card", "path": "manual-tests/out/m2/front.pdf" },
    { "id": "card-back", "path": "manual-tests/out/m2/back.pdf" }
  ],
  "scheme": {
    "kind": "step-repeat",
    "max_rows": 2,
    "max_cols": 3,
    "h_space_pt": 0.0,
    "v_space_pt": 0.0,
    "bleed_mode": "bleed",
    "scale": "none",
    "back": { "source": "card-back" }
  },
  "sheet": { "size_pt": [800, 800], "gripper_pt": 0.0, "margin_pt": 0.0, "work_style": "work-and-turn" },
  "marks": { "crop": {} },
  "output": { "pdf_version": "1.6" }
}
